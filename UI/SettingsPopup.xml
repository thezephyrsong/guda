<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/">

    <!-- Settings Popup Frame -->
    <Frame name="Guda_SettingsPopup" toplevel="true" movable="true" enableMouse="true" hidden="true" parent="UIParent" frameStrata="DIALOG">
        <Size>
            <AbsDimension x="500" y="525"/>
        </Size>

        <Anchors>
            <Anchor point="CENTER" relativePoint="CENTER" relativeTo="UIParent">
                <Offset>
                    <AbsDimension x="0" y="0"/>
                </Offset>
            </Anchor>
        </Anchors>

        <Layers>
            <!-- Title -->
            <Layer level="ARTWORK">
                <FontString name="$parent_Title" inherits="GameFontNormalLarge">
                    <Anchors>
                        <Anchor point="TOP">
                            <Offset>
                                <AbsDimension x="0" y="-20"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="1" g="0.82" b="0"/>
                </FontString>
            </Layer>
        </Layers>

        <Frames>
            <!-- Close Button -->
            <Button name="$parent_CloseButton" inherits="UIPanelCloseButton">
                <Anchors>
                    <Anchor point="TOPRIGHT">
                        <Offset>
                            <AbsDimension x="-5" y="-5"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnClick>
                        Guda_SettingsPopup:Hide()
                    </OnClick>
                </Scripts>
            </Button>

            <!-- Tab Buttons (7 tabs resized to 65px width to fit container margins perfectly) -->
            <Button name="Guda_SettingsPopup_GeneralTabButton" enableMouse="true">
                <Size><AbsDimension x="65" y="28"/></Size>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT">
                        <Offset><AbsDimension x="18" y="-55"/></Offset>
                    </Anchor>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parent_Bg" setAllPoints="true">
                            <Color r="1" g="1" b="1" a="0.3"/>
                        </Texture>
                    </Layer>
                    <Layer level="OVERLAY">
                        <FontString name="$parent_Text" inherits="GameFontNormal" text="General">
                            <Anchors><Anchor point="CENTER"/></Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Scripts>
                    <OnClick>Guda_SettingsPopup_SelectTab("general")</OnClick>
                </Scripts>
            </Button>

            <Button name="Guda_SettingsPopup_LayoutTabButton" enableMouse="true">
                <Size><AbsDimension x="65" y="28"/></Size>
                <Anchors>
                    <Anchor point="LEFT" relativeTo="Guda_SettingsPopup_GeneralTabButton" relativePoint="RIGHT">
                        <Offset><AbsDimension x="2" y="0"/></Offset>
                    </Anchor>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parent_Bg" setAllPoints="true">
                            <Color r="1" g="1" b="1" a="0.1"/>
                        </Texture>
                    </Layer>
                    <Layer level="OVERLAY">
                        <FontString name="$parent_Text" inherits="GameFontNormal" text="Layout">
                            <Anchors><Anchor point="CENTER"/></Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Scripts>
                    <OnClick>Guda_SettingsPopup_SelectTab("layout")</OnClick>
                </Scripts>
            </Button>

            <Button name="Guda_SettingsPopup_IconsTabButton" enableMouse="true">
                <Size><AbsDimension x="65" y="28"/></Size>
